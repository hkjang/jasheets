JASHEETS_VERSION=REPLACED_BY_RELEASE

# The only required application setting.
POSTGRES_DSN=postgresql://jasheets:CHANGE_ME@postgres.example.internal:5432/jasheets?schema=public

# Bind these ports to the addresses consumed by your Ingress/controller.
JASHEETS_WEB_BIND=127.0.0.1:3000
JASHEETS_API_BIND=127.0.0.1:4000
