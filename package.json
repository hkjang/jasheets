{
  "name": "jasheets",
  "version": "0.1.0",
  "private": true,
  "description": "A Sheets-like web spreadsheet service",
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "start": "turbo run start",
    "start:prod": "turbo run start:prod",
    "test": "turbo run test",
    "test:e2e": "playwright test",
    "test:e2e:real": "bash scripts/run-real-e2e.sh",
    "test:performance": "pnpm --filter web test:performance",
    "lint": "turbo run lint",
    "clean": "turbo run clean && rimraf node_modules",
    "db:up": "docker compose -f docker/docker-compose.dev.yml up -d",
    "db:down": "docker compose -f docker/docker-compose.dev.yml down",
    "db:up:prod": "docker compose -f docker/docker-compose.prod.yml up -d",
    "db:down:prod": "docker compose -f docker/docker-compose.prod.yml down",
    "db:generate": "turbo run prisma:generate",
    "db:migrate": "turbo run prisma:migrate",
    "db:verify": "bash scripts/verify-migrations.sh",
    "db:studio": "turbo run prisma:studio",
    "security:audit": "pnpm audit --audit-level high"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "rimraf": "^5.0.10",
    "turbo": "^2.10.5",
    "typescript": "^5.9.3"
  },
  "packageManager": "pnpm@9.14.4",
  "pnpm": {
    "overrides": {
      "postcss": ">=8.5.10",
      "serialize-javascript": ">=7.0.5",
      "fast-uri": ">=3.1.4",
      "sharp": ">=0.35.0"
    }
  },
  "engines": {
    "node": ">=20.9.0"
  }
}
